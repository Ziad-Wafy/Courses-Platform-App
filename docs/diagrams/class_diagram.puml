@startuml class_diagram

abstract class User {
  +userId: String
  +name: String
  +email: String
  +login()
  +logout()
}

class Student {
  +attendanceRate: float
  +performanceScore: float
  +enrollCourse()
  +submitAssignment()
  +takeQuiz()
}

class Teacher {
  +createCourse()
  +uploadContent()
  +createQuiz()
  +generateReport()
}

class Course {
  +courseId: String
  +title: String
  +description: String
  +isFreePreview: bool
  +addLecture()
  +addAssignment()
}

class Lecture {
  +lectureId: String
  +videoUrl: String
  +duration: int
}

class Quiz {
  +quizId: String
  +totalMarks: int
  +evaluate()
}

class Assignment {
  +assignmentId: String
  +deadline: Date
  +submit()
}

class Notification {
  +notificationId: String
  +message: String
  +timestamp: DateTime
}

User <|-- Student
User <|-- Teacher

Teacher "1" -- "many" Course
Course "1" -- "many" Lecture
Course "1" -- "many" Quiz
Course "1" -- "many" Assignment
Student "many" -- "many" Course
Student -- Notification

@enduml